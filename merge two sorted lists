# Definition for singly-linked list.
class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next

class Solution:
    def mergeTwoLists(self, list1: Optional[ListNode], list2: Optional[ListNode]) -> Optional[ListNode]:
        # Create a dummy node to act as the start of the merged list
        dummy = ListNode(-1)
        # 'current' pointer will build the new list
        current = dummy
        
        # Loop while both lists have elements
        while list1 and list2:
            if list1.val <= list2.val:
                current.next = list1
                list1 = list1.next  # Move list1 pointer forward
            else:
                current.next = list2
                list2 = list2.next  # Move list2 pointer forward
            
            current = current.next  # Move the merged list pointer forward
            
        # If any elements are left over in either list, append them
        current.next = list1 if list1 else list2
        
        # The head of the merged list is the node after the dummy node
        return dummy.next
